{
  "name": "gtheme_03",
  "productName": "gTheme03",
  "version": "3.23.0",
  "description": "Theme Framework for WordPress",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/geminorum/gtheme_03/",
  "author": {
    "name": "Nasser Rafie",
    "email": "contact@geminorum.ir",
    "url": "https://geminorum.ir"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/geminorum/gtheme_03.git"
  },
  "bugs": {
    "url": "https://github.com/geminorum/gtheme_03/issues"
  },
  "scripts": {
    "gulp": "./node_modules/gulp/bin/gulp.js",
    "changes": "echo ### > CHANGES.temp && git changelog >> CHANGES.temp && (echo. & echo.) >> CHANGES.temp && type CHANGES.md >> CHANGES.temp && type CHANGES.temp > CHANGES.md && del CHANGES.temp",
    "clean": "gulp clean",
    "i18n:gulp": "gulp pot",
    "i18n:json": "wp i18n make-json languages --no-purge --skip-plugins --skip-themes --skip-packages",
    "i18n:php": "wp i18n make-php ./languages",
    "i18n:pot:sub": "wp i18n make-pot . ./languages/gtheme.pot --subtract=\"../gtheme_03/languages/gtheme_03.pot\" --exclude=\".temp,.github,.vscode,assets/vendor,js/vendor,gulpfile.mjs\" --file-comment='' --headers='{\"Last-Translator\":\"NULL\",\"Language-Team\":\"NULL\",\"Report-Msgid-Bugs-To\":\"https://github.com/geminorum/gtheme_03/issues\"}' --skip-plugins --skip-themes --skip-packages",
    "i18n:pot": "wp i18n make-pot . ./languages/gtheme.pot --exclude=\".temp,.github,.vscode,assets/vendor,js/vendor,gulpfile.mjs\" --file-comment='' --headers='{\"Last-Translator\":\"NULL\",\"Language-Team\":\"NULL\",\"Report-Msgid-Bugs-To\":\"https://github.com/geminorum/gtheme_03/issues\"}' --skip-plugins --skip-themes --skip-packages",
    "minor": "gulp bump",
    "patch": "gulp bump --patch",
    "ready": "gulp build",
    "refresh": "gulp sass",
    "release": "gulp github:tag && start https://github.com/geminorum/gtheme_03/releases",
    "watch": "gulp watch",
    "home": "start https://github.com/geminorum/gtheme_03/",
    "issues": "start https://github.com/geminorum/gtheme_03/issues",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {},
  "devDependencies": {
    "@wordpress/babel-preset-default": "^8.47.0",
    "@wordpress/browserslist-config": "^6.47.0",
    "@wordpress/stylelint-config": "^23.39.0",
    "autoprefixer": "^10.5.0",
    "browserslist": "^4.28.2",
    "cssnano": "^8.0.1",
    "del": "^8.0.1",
    "fancy-log": "^2.0.0",
    "gulp": "^5.0.1",
    "gulp-livereload": "^4.0.2",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^10.0.0",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "postcss": "^8.5.15",
    "postcss-inline-svg": "^6.0.0",
    "rtlcss": "^4.3.0",
    "sass": "^1.100.0",
    "semistandard": "^17.0.0",
    "stylelint": "^17.12.0",
    "stylelint-scss": "^7.1.1"
  },
  "optionalDependencies": {
    "@popperjs/core": "^2.11.8",
    "autosize": "^6.0.1",
    "bootstrap": "^5.3.8",
    "genericons-neue": "^4.0.5",
    "select2-bootstrap-5-theme": "^1.3.0"
  },
  "babel": {
    "presets": [
      "@wordpress/babel-preset-default"
    ]
  },
  "browserslist": [
    "extends @wordpress/browserslist-config"
  ],
  "semistandard": {
    "ignore": [
      "/js/vendor/",
      "*.min.js"
    ],
    "globals": [
      "jQuery",
      "Vue",
      "wp",
      "ajaxurl",
      "confirm",
      "alert",
      "top",
      "self"
    ]
  },
  "readme": "ERROR: No README data found!",
  "private": true
}
