{
  "input": {
    "clean": "./css/*.css",
    "sass": "./stylesheets/**/*.scss",
    "watch": [
      "./stylesheets/**/*.scss"
    ]
  },
  "output": {
    "css": "./css"
  },
  "tmp": [],
  "sass": {
    "silenceDeprecations": [
      "import",
      "color-functions",
      "if-function",
      "global-builtin"
    ],
    "errLogToConsole": true,
    "loadPaths": [
      "./stylesheets/modules",
      "node_modules/bootstrap/scss"
    ]
  },
  "cssnano": {
    "dev": {
      "preset": [
        "default", {
          "svgo": false,
          "zindex": false,
          "normalizeWhitespace": false,
          "discardComments": false
        }
      ]
    },
    "build": {
      "preset": [
        "default", {
          "svgo": false,
          "zindex": false,
          "discardComments": {
            "removeAll": true
          }
        }
      ]
    }
  },
  "autoprefixer": {
    "dev": {},
    "build": {
      "cascade": false
    }
  }
}
